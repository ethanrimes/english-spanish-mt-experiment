# Copy to .env and fill in. .env is gitignored.
# This project supports two compute backends: vast.ai (cheaper, no quota,
# default) and Azure ML (managed but quota-gated). Fill in whichever you use.

# ---- vast.ai (preferred for research / one-shot training) ----
VAST_API_KEY=                           # from https://cloud.vast.ai/cli/
VAST_INSTANCE_ID=                       # filled by scripts/vastai_provision.py
VAST_SSH_HOST=                          # filled by scripts/vastai_provision.py
VAST_SSH_PORT=                          # filled by scripts/vastai_provision.py
VAST_SSH_USER=root                      # vast.ai default

# ---- Azure (optional, only if you have GPU quota) ----
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_ML_WORKSPACE=
AZURE_REGION=westcentralus

# Storage for raw + processed data and checkpoints
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=en-es-mt
# Either rely on `az login` / DefaultAzureCredential (preferred) or:
# AZURE_STORAGE_CONNECTION_STRING=

# Compute target (created in AML workspace)
# Default is the cheap A10 cluster. Switch to gpu-a100-1x for the T5M run
# or when iterating quickly on hyperparameters.
AZURE_COMPUTE_NAME=gpu-a10-1x
AZURE_VM_SIZE=Standard_NV36ads_A10_v5

# ---- Weights & Biases ----
WANDB_API_KEY=
WANDB_PROJECT=en-es-mt
WANDB_ENTITY=

# ---- HuggingFace ----
HF_TOKEN=
HF_HOME=./data/hf_cache
