# Copy to .env and fill in. .env is gitignored.
# ---- Azure ----
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_ML_WORKSPACE=
AZURE_REGION=eastus

# Storage for raw + processed data and checkpoints
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=en-es-mt
# Either rely on `az login` / DefaultAzureCredential (preferred) or:
# AZURE_STORAGE_CONNECTION_STRING=

# Compute target (created in AML workspace)
AZURE_COMPUTE_NAME=gpu-a100-1x
AZURE_VM_SIZE=Standard_NC24ads_A100_v4

# ---- Weights & Biases ----
WANDB_API_KEY=
WANDB_PROJECT=en-es-mt
WANDB_ENTITY=

# ---- HuggingFace ----
HF_TOKEN=
HF_HOME=./data/hf_cache
